{
	"$schema": "https://opencode.ai/config.json",
	"instructions": [
		"AGENTS.md",
		"README.md"
	],
	"lsp": true,
	"mcp": {
		"nuxt": {
			"type": "remote",
			"url": "https://nuxt.com/mcp",
			"enabled": true,
			"timeout": 10000
		},
		"nuxt-ui": {
			"type": "remote",
			"url": "https://ui.nuxt.com/mcp",
			"enabled": true,
			"timeout": 10000
		}
	},
	"watcher": {
		"ignore": [
			".git/**",
			"node_modules/**",
			".nuxt/**",
			".output/**",
			".nitro/**",
			".data/**",
			".cache/**",
			"dist/**"
		]
	}
}